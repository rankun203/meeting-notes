{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceRecords",
  "version": "0.1.0",
  "identifier": "org.rankun.meeting-notes",
  "build": {
    "frontendDist": "../webui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceRecords",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 },
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.local/share/org.rankun.meeting-notes/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "VoiceRecords (主簿) — a voice meeting notes app",
    "longDescription": "Record voice meetings, transcribe them, attribute speakers, and keep them forever. Local-first. 主簿.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  }
}
